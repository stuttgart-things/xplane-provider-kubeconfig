FROM golang:1.24-alpine AS builder

RUN apk add --no-cache git

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -o /provider ./cmd/provider

FROM gcr.io/distroless/static@sha256:d9f9472a8f4541368192d714a995eb1a99bab1f7071fc8bde261d7eda3b667d8

COPY --from=builder /provider /usr/local/bin/crossplane-kubeconfig-provider

USER 65532
ENTRYPOINT ["crossplane-kubeconfig-provider"]
